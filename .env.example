# ============================================================
# NimbusFlow Customer Success FTE — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# ── Gemini (via OpenAI-compatible endpoint) ──────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fte_db
POSTGRES_USER=fte_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://fte_user:changeme@localhost:5432/fte_db

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=fte-message-processor

# ── Gmail API ────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=./secrets/gmail-credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail-token.json
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-push
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Twilio WhatsApp ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=NimbusFlow Customer Success FTE

# ── Channel Limits ───────────────────────────────────────────
MAX_EMAIL_LENGTH=2000
MAX_WHATSAPP_LENGTH=1600
MAX_WEBFORM_LENGTH=1000

# ── Channel Toggles ──────────────────────────────────────────
GMAIL_ENABLED=true
WHATSAPP_ENABLED=true
WEBFORM_ENABLED=true

# ── Performance ──────────────────────────────────────────────
RESPONSE_TIMEOUT_SECONDS=30
MAX_KB_RESULTS=5
KB_SIMILARITY_THRESHOLD=0.7

# ── Escalation SLAs ──────────────────────────────────────────
SLA_CRITICAL_HOURS=2
SLA_HIGH_HOURS=2
SLA_NORMAL_HOURS=4
SLA_LOW_HOURS=24
