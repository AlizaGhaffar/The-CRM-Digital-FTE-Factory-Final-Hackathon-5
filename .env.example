# =
# NimbusFlow Customer Success FTE — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =

# ── Groq (GroqCloud) via OpenAI-compatible endpoint ──────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=
GROQ_EMBEDDING_MODEL=
# Legacy aliases (kept for backward compat)
GROK_API_KEY=
GROK_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=

# ── PostgreSQL (NeonDB) ──────────────────────────────────────
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_GROUP_ID=
KAFKA_TOPIC_WEB_FORM=
KAFKA_TOPIC_EMAIL=
KAFKA_TOPIC_WHATSAPP=

# ── Gmail API ────────────────────────────────────────────────
GMAIL_USER_ID=
GMAIL_CREDENTIALS_PATH=
GMAIL_CREDENTIALS_FILE=
GMAIL_TOKEN_PATH=
GMAIL_TOKEN_FILE=
GMAIL_CHECK_INTERVAL_SECONDS=
GMAIL_LABEL_FILTER=
GMAIL_PUBSUB_TOPIC=
GOOGLE_CLOUD_PROJECT=

# ── Twilio WhatsApp ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=
API_PORT=
API_RELOAD=
CORS_ORIGINS=

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=
LOG_LEVEL=
APP_NAME=

# ── Channel Limits ───────────────────────────────────────────
MAX_EMAIL_LENGTH=
MAX_WHATSAPP_LENGTH=
MAX_WEBFORM_LENGTH=

# ── Channel Toggles ──────────────────────────────────────────
GMAIL_ENABLED=
WHATSAPP_ENABLED=
WEBFORM_ENABLED=

# ── Performance ──────────────────────────────────────────────
RESPONSE_TIMEOUT_SECONDS=
MAX_KB_RESULTS=
KB_SIMILARITY_THRESHOLD=

# ── Escalation SLAs ──────────────────────────────────────────
SLA_CRITICAL_HOURS=
SLA_HIGH_HOURS=
SLA_NORMAL_HOURS=
SLA_LOW_HOURS=
