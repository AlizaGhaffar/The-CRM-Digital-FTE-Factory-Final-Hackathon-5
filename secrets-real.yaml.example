# ============================================================
# NimbusFlow Customer Success FTE — REAL SECRETS TEMPLATE
#
# PURPOSE: Fill this file with your actual credentials,
#          then apply it to Kubernetes. NEVER commit this file.
#
# HOW TO USE:
#   1. Copy this file:
#        cp secrets-real.yaml.example secrets-real.yaml
#   2. Fill in every REPLACE_WITH_... value (see instructions below)
#   3. Apply to cluster:
#        kubectl apply -f secrets-real.yaml
#   4. Verify:
#        kubectl get secret fte-secrets -n customer-success-fte
#   5. Delete the local file after applying:
#        rm secrets-real.yaml   (never leave it on disk)
#
# ENCODING ALL VALUES:
#   Every value in the `data:` section MUST be base64-encoded.
#   Command: echo -n "your-actual-value" | base64
#   On Mac:  echo -n "your-actual-value" | base64
#   On Linux: echo -n "your-actual-value" | base64
#   On Windows (PowerShell):
#             [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("your-value"))
#
# WHERE TO GET EACH KEY:
#   See: docs/environment-setup.md for step-by-step instructions
# ============================================================

# ── Secret 1: API Keys and Service Credentials ────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: fte-secrets
  namespace: customer-success-fte
  labels:
    app.kubernetes.io/name: customer-success-fte
    app.kubernetes.io/part-of: nimbusflow
type: Opaque
data:

  # ── PostgreSQL Password ────────────────────────────────────────────────────
  #
  # WHAT:    Password for the fte_user PostgreSQL account
  # WHERE:   You set this when installing PostgreSQL via Helm (--set auth.password=...)
  #          or when running docker-compose locally (POSTGRES_PASSWORD in .env)
  # FORMAT:  Any string — alphanumeric + special characters OK
  # EXAMPLE: echo -n "s3curePassw0rd!" | base64  →  czNjdXJlUGFzc3cwcmQh
  #
  POSTGRES_PASSWORD: "REPLACE_WITH_BASE64_POSTGRES_PASSWORD"
  #                   ^ e.g.: czNjdXJlUGFzc3cwcmQh

  # ── Gemini API Key ─────────────────────────────────────────────────────────
  #
  # WHAT:    Google Gemini API key for LLM inference (primary AI model)
  # WHERE:   https://aistudio.google.com/app/apikey
  #          → Click "Create API key" → Select or create a Google Cloud project
  # FORMAT:  Starts with "AIza" followed by 35 characters
  # EXAMPLE: echo -n "AIzaSyABC123..." | base64
  # NOTE:    Free tier gives 15 RPM / 1M tokens/day — sufficient for hackathon
  #
  GEMINI_API_KEY: "REPLACE_WITH_BASE64_GEMINI_API_KEY"
  #                ^ e.g.: QUl6YVN5QUJDMTIZ...

  # ── OpenAI API Key ─────────────────────────────────────────────────────────
  #
  # WHAT:    OpenAI API key — used for text-embedding-ada-002 (knowledge base search)
  #          and as fallback if Gemini is unavailable
  # WHERE:   https://platform.openai.com/api-keys
  #          → Create new secret key → Give it a name → Copy immediately (shown once)
  # FORMAT:  Starts with "sk-" followed by 48+ characters
  # EXAMPLE: echo -n "sk-proj-abc123..." | base64
  # NOTE:    Only embedding calls use this — low cost. $0.0001 per 1K tokens.
  #          If you don't have OpenAI, set this to a dummy value and
  #          update queries.py to use a local embedding model instead.
  #
  OPENAI_API_KEY: "REPLACE_WITH_BASE64_OPENAI_API_KEY"
  #                ^ e.g.: c2stcHJvai1hYmMxMjM...

  # ── Twilio Account SID ────────────────────────────────────────────────────
  #
  # WHAT:    Twilio Account SID — identifies your Twilio account
  # WHERE:   https://console.twilio.com
  #          → Dashboard → Account Info → Account SID
  # FORMAT:  "AC" followed by 32 hex characters (total 34 chars)
  # EXAMPLE: echo -n "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" | base64
  # NOTE:    This is NOT secret on its own — it's always paired with AUTH_TOKEN
  #
  TWILIO_ACCOUNT_SID: "REPLACE_WITH_BASE64_TWILIO_ACCOUNT_SID"
  #                    ^ e.g.: QUN4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eA==

  # ── Twilio Auth Token ─────────────────────────────────────────────────────
  #
  # WHAT:    Twilio Auth Token — used to validate webhook signatures (HMAC-SHA1)
  # WHERE:   https://console.twilio.com
  #          → Dashboard → Account Info → Auth Token → Click eye icon to reveal
  # FORMAT:  32-character hex string
  # EXAMPLE: echo -n "your32hexchartoken0123456789abcd" | base64
  # WARNING: This is highly sensitive — anyone with this can send WhatsApp
  #          messages from your Twilio number. Rotate immediately if exposed.
  #
  TWILIO_AUTH_TOKEN: "REPLACE_WITH_BASE64_TWILIO_AUTH_TOKEN"
  #                   ^ e.g.: eW91cjMyaGV4Y2hhcnRva2VuMDEyMzQ1Njc4OWFiY2Q=

---

# ── Secret 2: Gmail OAuth2 Credentials ───────────────────────────────────────
#
# WHAT:    Two JSON files that allow the app to read/send Gmail on behalf of
#          your Google account via OAuth2
# WHERE:   See docs/environment-setup.md Section 3 for the full OAuth2 flow
#
# HOW TO ENCODE JSON FILES:
#   # Mac/Linux:
#   base64 -w0 gmail_credentials.json   # -w0 prevents line wrapping
#
#   # Or use kubectl directly (recommended — avoids manual encoding):
#   kubectl create secret generic fte-gmail-secrets \
#     --namespace customer-success-fte \
#     --from-file=gmail_credentials.json=./gmail_credentials.json \
#     --from-file=gmail_token.json=./gmail_token.json \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# NOTE:    If you use the kubectl command above, you do NOT need to fill in
#          the base64 values here — skip this secret entirely.
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: fte-gmail-secrets
  namespace: customer-success-fte
  labels:
    app.kubernetes.io/name: customer-success-fte
    app.kubernetes.io/part-of: nimbusflow
type: Opaque
data:

  # ── gmail_credentials.json ────────────────────────────────────────────────
  #
  # WHAT:    OAuth2 client credentials downloaded from Google Cloud Console
  # WHERE:   Google Cloud Console → APIs & Services → Credentials
  #          → Create Credentials → OAuth 2.0 Client ID → Desktop app
  #          → Download JSON → rename to gmail_credentials.json
  # FORMAT:  base64-encoded JSON file (no line breaks)
  # ENCODE:  base64 -w0 gmail_credentials.json
  #
  # The raw JSON looks like:
  # {
  #   "installed": {
  #     "client_id": "123456789-abc.apps.googleusercontent.com",
  #     "client_secret": "GOCSPX-...",
  #     "redirect_uris": ["http://localhost"],
  #     ...
  #   }
  # }
  #
  gmail_credentials.json: "REPLACE_WITH_BASE64_ENCODED_CREDENTIALS_JSON_FILE"

  # ── gmail_token.json ──────────────────────────────────────────────────────
  #
  # WHAT:    OAuth2 access+refresh token obtained by completing the OAuth2 flow
  # HOW:    Run this locally ONCE to generate the token:
  #
  #   python -c "
  #   from google_auth_oauthlib.flow import InstalledAppFlow
  #   flow = InstalledAppFlow.from_client_secrets_file(
  #       'gmail_credentials.json',
  #       ['https://www.googleapis.com/auth/gmail.modify']
  #   )
  #   creds = flow.run_local_server(port=0)
  #   import json
  #   with open('gmail_token.json', 'w') as f:
  #       f.write(creds.to_json())
  #   print('Saved gmail_token.json')
  #   "
  #
  #   A browser will open — log in with the Gmail account that will receive
  #   customer emails, grant access, then the token is saved.
  #
  # ENCODE:  base64 -w0 gmail_token.json
  # EXPIRY:  Refresh token does not expire unless revoked — no need to regenerate
  #
  gmail_token.json: "REPLACE_WITH_BASE64_ENCODED_TOKEN_JSON_FILE"
